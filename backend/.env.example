PORT=5000
HOST=0.0.0.0

# Local MongoDB (development)
# MONGO_URI=mongodb://127.0.0.1:27017/student_course_management

# MongoDB Atlas (production) - replace USER, PASSWORD, and CLUSTER
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/student_course_management?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
NODE_ENV=development

# Frontend URL for CORS (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3000
